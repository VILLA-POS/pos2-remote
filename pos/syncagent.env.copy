# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pos
POSTGRES_USER=dbadmin
POSTGRES_PASSWORD={DB_PASS}


TINYAUTH_URL=https://v-nta.com/tnapi/v1/{REALM}/auth/token
TINYAUTH_CLIENT_NAME=sync-manual
TINYAUTH_CLIENT_ID={SYNC_CLIENT_ID}
TINYAUTH_CLIENT_SECRET={SYNC_CLIENT_SECRET}

POLL_INTERVAL_MS=5000
BATCH_SIZE=20

SYNC_NODE_ID={NODE_ID}
SYNC_URL=https://v-nta.com/api

LOG_LEVEL=info
NODE_ENV=production

# set to true if the remote server uses a self-signed certificate
SYNC_TLS_INSECURE=false
